# DeepSeek API Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Database Configuration
DATABASE_URL=sqlite:///./data/character_seed.db

# Application Settings
DEBUG=True
API_V1_STR=/api

# ============================================================
# Langfuse LLM 可观测性（参考 https://juejin.cn/post/7633462423300407336）
# 全部可选：未配 KEY 时自动降级为 no-op，不影响主流程
# ============================================================
# 总开关：true=启用，false=关闭（默认）
LANGFUSE_ENABLED=false
# Public Key / Secret Key（在 Langfuse Settings → API Keys 复制）
# 自部署填 http://localhost:3000，Langfuse Cloud 留空（用默认值 https://cloud.langfuse.com）
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
# 采样率：1.0=全量，0.1=10%；高频场景建议 0.1~0.3
LANGFUSE_SAMPLE_RATE=1.0
# 发布版本标签（按版本切片查看 trace 时用，可选）
LANGFUSE_RELEASE=dev
